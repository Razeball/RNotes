{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-temp-read-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:scope-temp-recursive",
    "dialog:default"
  ]
}
