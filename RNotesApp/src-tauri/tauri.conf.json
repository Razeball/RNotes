{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rnotesapp",
  "version": "0.2.0",
  "identifier": "com.said5.rnotesapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rnotesapp",
        "width": 1000,
        "height": 600,
        "devtools": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$TEMP/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzQUM0MTg2QjE0MUI1MjgKUldRb3RVR3hoa0dzVTVIV3A2VWJ6SUs5dXMxc0Z1blhzdlRyUE5kZTJRNnptR0NBc1BoOTlsZUoK",
      "endpoints": [
        "https://github.com/Razeball/RNotes/releases/latest/download/latest.json"
      ]
    }
  }
}
